    def _fix_mojibake(self, out: Dict) -> None:
        fixes = [
            ('Ã©', 'é'), ('Ã¨', 'è'), ('Ãª', 'ê'), ('Ã\xa0', 'à'),
            ('Ã®', 'î'), ('Ã´', 'ô'), ('Ã¹', 'ù'), ('Ã§', 'ç'),
            ('Ã‰', 'É'), ('Ã€', 'À'), ('\xe2\x80\x99', "'"), ('\xe2\x80\x94', '—'),
        ]
        for key in list(out.keys()):
            if isinstance(out[key], str):
                for bad, good in fixes:
                    out[key] = out[key].replace(bad, good)
