    # Activé par le générateur si rendering=PLAYWRIGHT pour la découverte de
    # listings (sites SPA dont le HTML brut est vide).
    USE_PLAYWRIGHT_FOR_DISCOVERY = {{ use_playwright_for_discovery|default(False)|tojson }}

    def _fetch_listing_html(self, url: str):
        """Récupère le HTML d'une page listing. Utilise Playwright si la
        stratégie l'exige (USE_PLAYWRIGHT_FOR_DISCOVERY=True), sinon requests."""
        if not self.USE_PLAYWRIGHT_FOR_DISCOVERY:
            try:
                resp = self.session.get(url, timeout=self.HTTP_TIMEOUT)
                if resp.status_code != 200:
                    return None
                return resp.text
            except Exception:
                return None

        try:
            from playwright.sync_api import sync_playwright
        except ImportError:
            try:
                resp = self.session.get(url, timeout=self.HTTP_TIMEOUT)
                if resp.status_code != 200:
                    return None
                return resp.text
            except Exception:
                return None

        try:
            if not hasattr(self, '_pw_listing'):
                self._pw_listing = sync_playwright().start()
                self._pw_listing_browser = self._pw_listing.chromium.launch(headless=True)
                self._pw_listing_ctx = self._pw_listing_browser.new_context(
                    user_agent=self.session.headers.get('User-Agent', ''),
                    locale='fr-CA',
                )
            page = self._pw_listing_ctx.new_page()
            try:
                page.goto(url, timeout=20000, wait_until='networkidle')
            except Exception:
                try:
                    page.goto(url, timeout=20000, wait_until='domcontentloaded')
                    page.wait_for_timeout(3000)
                except Exception:
                    page.close()
                    return None
            html = page.content()
            page.close()
            return html
        except Exception:
            return None

    def _is_soft_404(self, soup: BeautifulSoup) -> bool:
        title = soup.find('title')
        if title:
            t = title.get_text(strip=True).lower()
            if any(w in t for w in ('404', 'introuvable', 'not found', 'page removed', 'erreur')):
                return True
        body_text = soup.get_text(separator=' ', strip=True)
        if len(body_text) < 500:
            return True
        h1 = soup.find('h1')
        if h1:
            h1_text = h1.get_text(strip=True).lower()
            if any(w in h1_text for w in ('404', 'not found', 'introuvable', 'page non trouvée')):
                return True
        return False
