    def scrape(self, categories: List[str] = None, inventory_only: bool = False) -> Dict[str, Any]:
        start_time = time.time()

        if categories is None:
            categories = {{ default_categories|default("['inventaire', 'occasion']") }}

        print(f"\n{'='*70}")
        print(f"  SCRAPER DÉDIÉ: {self.SITE_NAME}")
        print(f"{'='*70}")
        print(f"  Site: {self.SITE_URL}")
        print(f"  Catégories: {categories}")

{% if extraction_method == 'api_json' %}
        products = self._scrape_via_api()
{% elif extraction_method == 'listing_only' %}
        products = []
        for cat_key, config in self.LISTING_PAGES.items():
            if not self._category_matches(cat_key, categories):
                continue
            products.extend(self._scrape_listing_page(config))
{% else %}
        # Discovery URLs (sitemap/listing/api selon stratégie de génération)
        product_urls = self.discover_product_urls(categories)
        print(f"\n  {len(product_urls)} URLs de produits découvertes")

        if not product_urls:
            elapsed = time.time() - start_time
            return self._empty_result(elapsed)

        products = self._extract_all(product_urls)
{% endif %}

{% if needs_state_classification %}
        for p in products:
            if not p.get('etat'):
                p['etat'] = self._classify_state(p)
{% endif %}

        if inventory_only:
            products = [p for p in products if p.get('sourceCategorie') != 'catalogue']

        pre_group = len(products)
        products = self._group_identical_products(products)
        if pre_group != len(products):
            grouped = pre_group - len(products)
            print(f"\n  Regroupement: {pre_group} -> {len(products)} ({grouped} combinés)")

        elapsed = time.time() - start_time

        print(f"\n{'='*70}")
        print(f"  {self.SITE_NAME}: {len(products)} produits en {elapsed:.1f}s")
        print(f"{'='*70}")

        return {
            'products': products,
            'metadata': {
                'site_url': self.SITE_URL,
                'site_name': self.SITE_NAME,
                'scraper_type': 'dedicated',
                'scraper_module': self.SITE_SLUG,
                'products_count': len(products),
                'urls_processed': len(products),
                'execution_time_seconds': round(elapsed, 2),
                'categories': categories,
                'cache_status': 'dedicated',
            },
            'scraper_info': {
                'type': 'dedicated',
                'module': self.SITE_SLUG,
                'selectors': 'generated',
            }
        }
{% if extraction_method == 'listing_only' %}

    def _scrape_listing_page(self, config: Dict) -> List[Dict]:
        products = []
        listing_url = config['url']
        etat = config.get('etat', 'neuf')
        source_cat = config.get('sourceCategorie', 'inventaire')

        try:
            resp = self.session.get(listing_url, timeout=self.HTTP_TIMEOUT)
            if resp.status_code != 200:
                return products
            soup = BeautifulSoup(resp.text, 'lxml')

            total = self._parse_total_products(soup) if hasattr(self, '_parse_total_products') else 0
            total_pages = max(1, math.ceil(total / self.PRODUCTS_PER_PAGE)) if total > 0 else 1

            items = soup.select('{{ item_selector }}')
            for item in items:
                p = self._extract_from_listing_item(item, listing_url, etat, source_cat)
                if p:
                    products.append(p)

            for page_num in range(2, total_pages + 1):
                page_url = self._build_paginated_url(listing_url, '{{ pagination_param }}', page_num)
                time.sleep({{ request_delay }})
                try:
                    resp_p = self.session.get(page_url, timeout=self.HTTP_TIMEOUT)
                    if resp_p.status_code == 200:
                        soup_p = BeautifulSoup(resp_p.text, 'lxml')
                        for item in soup_p.select('{{ item_selector }}'):
                            p = self._extract_from_listing_item(item, listing_url, etat, source_cat)
                            if p:
                                products.append(p)
                except Exception:
                    break
        except Exception:
            pass
        return products

{% endif %}
{% if extraction_method == 'api_json' %}

    def _scrape_via_api(self) -> List[Dict]:
        raw_items = self._fetch_all_api_products()
        products = []
        for raw in raw_items:
            p = self._map_api_product(raw)
            if p:
                p['sourceSite'] = self.SITE_URL
                p['quantity'] = 1
                p['groupedUrls'] = [p.get('sourceUrl', self.SITE_URL)]
                products.append(p)
        return products
{% endif %}
